<UserControl
	x:Class="BrowserPicker.UI.Views.BrowserList"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:converters="clr-namespace:BrowserPicker.UI.Converters"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:ui="clr-namespace:BrowserPicker.UI"
	xmlns:viewModels="clr-namespace:BrowserPicker.UI.ViewModels"
	d:DataContext="{d:DesignInstance viewModels:ApplicationViewModel,
									 d:IsDesignTimeCreatable=true}"
	mc:Ignorable="d">
	<UserControl.Resources>
		<ResourceDictionary>
			<converters:IconFileToImageConverter x:Key="IconConverter" />
			<converters:ContainerColorConverter x:Key="ContainerColorConverter" />
			<converters:ContainerIconConverter x:Key="ContainerIconConverter" />
			<converters:PickerUrlBarMaxWidthConverter x:Key="PickerUrlBarMaxWidthConverter" />
			<Style x:Key="RememberValueTextBlockStyle" TargetType="TextBlock">
				<Setter Property="MaxWidth" Value="235" />
				<Setter Property="Foreground" Value="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" />
				<Setter Property="TextTrimming" Value="CharacterEllipsis" />
				<Setter Property="TextWrapping" Value="NoWrap" />
			</Style>
		</ResourceDictionary>
	</UserControl.Resources>
	<Grid MinWidth="390" MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource PickerUrlBarMaxWidthConverter}}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<StackPanel Orientation="Vertical">
			<StackPanel Orientation="Horizontal">
				<Image Height="16" Margin="5" Source="{DynamicResource DefaultIcon}" />
				<TextBlock Margin="0,5">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Configuration.AutoCloseOnFocusLost}" Value="False">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
					<Hyperlink Command="{Binding PinWindow}" TextDecorations="None" ToolTip="Toggle whether this picker window stays open when it loses focus">
						<Hyperlink.Style>
							<Style TargetType="{x:Type Hyperlink}">
								<Setter Property="Foreground" Value="Silver" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Pinned}" Value="True">
										<Setter Property="Foreground" Value="Orange" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Hyperlink.Style>
						📌
					</Hyperlink>
				</TextBlock>
				<TextBlock Margin="0,5">
					<Hyperlink Command="{Binding CopyUrl}" TextDecorations="None" ToolTip="Copy the URL to the clipboard">
						<Hyperlink.Style>
							<Style TargetType="{x:Type Hyperlink}">
								<Setter Property="Foreground" Value="Silver" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Copied}" Value="True">
										<Setter Property="Foreground" Value="White" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Hyperlink.Style>
						📋
					</Hyperlink>
					<Hyperlink Command="{Binding Edit}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" TextDecorations="None" ToolTip="Edit the URL before opening it">
						✏
					</Hyperlink>
				</TextBlock>
				<TextBlock Margin="5,5,0,0" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="Redirected URL">
					<TextBlock.Style>
						<Style>
							<Style.Triggers>
								<DataTrigger Binding="{Binding Url.IsShortenedURL}" Value="False">
									<Setter Property="UIElement.Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
			</StackPanel>
			<!--  Wrapped URL (omnibox-style bar); MaxHeight caps height so absurd URLs do not dominate the picker. Tooltip explains local-only hints.  -->
			<Border
				Margin="2"
				Padding="6,4"
				HorizontalAlignment="Stretch"
				Background="{DynamicResource {x:Static ui:App.UrlBarBackgroundBrushKey}}"
				BorderBrush="{DynamicResource {x:Static ui:App.UrlBarBorderBrushKey}}"
				BorderThickness="1"
				CornerRadius="5">
				<Border.ToolTip>
					<ToolTip>
						<TextBlock MaxWidth="420" Text="{Binding Url.SecurityPresentation.ToolTip}" TextWrapping="Wrap" />
					</ToolTip>
				</Border.ToolTip>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Image
						Grid.Column="0"
						Width="16"
						Height="16"
						Margin="0,2,6,0"
						VerticalAlignment="Top"
						Source="{Binding Url.FavIcon, Converter={StaticResource IconConverter}}">
						<Image.Style>
							<Style TargetType="Image">
								<Setter Property="Visibility" Value="Visible" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Url.FavIconProbed}" Value="False">
										<Setter Property="Visibility" Value="Collapsed" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Image.Style>
					</Image>
					<TextBlock
						Grid.Column="1"
						MinWidth="0"
						MaxHeight="76"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Top"
						ui:UrlTextBlockSegments.Segments="{Binding Url.SecurityPresentation.Segments}"
						Foreground="{DynamicResource {x:Static ui:App.UrlBarForegroundBrushKey}}"
						LineHeight="18"
						LineStackingStrategy="BlockLineHeight"
						TextAlignment="Left"
						TextTrimming="CharacterEllipsis"
						TextWrapping="Wrap" />
				</Grid>
			</Border>
		</StackPanel>
		<ScrollViewer x:Name="BrowserListScroll" Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
			<ItemsControl ItemsSource="{Binding PickerChoices}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Vertical" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.Resources>
					<DataTemplate DataType="{x:Type viewModels:BrowserProfileViewModel}">
						<StackPanel Margin="2">
							<!--  Same column layout and min height as browser rows (chevron + privacy columns reserved) for visual alignment  -->
							<Border
								MinHeight="72"
								Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}"
								BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
								BorderThickness="1"
								CornerRadius="5">
								<Grid MinHeight="72" VerticalAlignment="Stretch">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<Button
										Grid.Column="0"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"
										Command="{Binding Select}"
										CommandParameter="{Binding Path=DataContext.Url.TargetURL, RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Grid MinHeight="72" VerticalAlignment="Stretch" Background="Transparent" Cursor="Hand">
													<Grid.Style>
														<Style>
															<Style.Triggers>
																<Trigger Property="Grid.IsMouseOver" Value="True">
																	<Setter Property="Grid.Background" Value="#22ffffff" />
																</Trigger>
															</Style.Triggers>
														</Style>
													</Grid.Style>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition Width="*" MinWidth="230" />
													</Grid.ColumnDefinitions>
													<Image
														Width="40"
														Height="40"
														Margin="20,0,0,0"
														VerticalAlignment="Center"
														d:DataContext="{DynamicResource DefaultIcon}"
														DataContext="{Binding IconPath, Converter={StaticResource IconConverter}}">
														<Image.Style>
															<Style TargetType="{x:Type Image}">
																<Setter Property="Source" Value="{Binding}" />
																<Style.Triggers>
																	<DataTrigger Binding="{Binding}" Value="{x:Null}">
																		<Setter Property="Source" Value="{DynamicResource DefaultIcon}" />
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Image.Style>
													</Image>
													<StackPanel
														Grid.Column="1"
														MinWidth="310"
														Margin="20,0,20,0"
														VerticalAlignment="Center"
														Orientation="Horizontal">
														<Path
															Width="16"
															Height="16"
															Margin="0,0,10,0"
															VerticalAlignment="Center"
															Data="{Binding Model.ContainerIcon, Converter={StaticResource ContainerIconConverter}}"
															Fill="{Binding Model.IconColor, Converter={StaticResource ContainerColorConverter}}"
															Stretch="Uniform">
															<Path.Style>
																<Style TargetType="Path">
																	<Setter Property="Visibility" Value="Visible" />
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding Model.ContainerIcon}" Value="{x:Null}">
																			<Setter Property="Visibility" Value="Collapsed" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</Path.Style>
														</Path>
														<TextBlock
															VerticalAlignment="Center"
															FontSize="18"
															Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
															LineHeight="22"
															Text="{Binding FlatDisplayName}">
															<TextBlock.Style>
																<Style>
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding IsRunning}" Value="True">
																			<Setter Property="TextBlock.FontWeight" Value="Bold" />
																		</DataTrigger>
																		<DataTrigger Binding="{Binding IsRunning}" Value="False">
																			<Setter Property="TextBlock.FontStyle" Value="Italic" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</TextBlock.Style>
														</TextBlock>
													</StackPanel>
												</Grid>
											</ControlTemplate>
										</Button.Template>
									</Button>
									<Border Grid.Column="1" Width="34" Background="Transparent" IsHitTestVisible="False" />
									<Button
										Grid.Column="2"
										VerticalAlignment="Stretch"
										Command="{Binding SelectPrivacy}"
										IsEnabled="{Binding HasPrivacyMode}"
										ToolTip="{Binding PrivacyTooltip}">
										<Button.Style>
											<Style TargetType="Button">
												<Style.Triggers>
													<Trigger Property="IsEnabled" Value="False">
														<Setter Property="UIElement.Visibility" Value="Collapsed" />
													</Trigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<Button.Template>
											<ControlTemplate>
												<Border
													Width="40"
													Height="40"
													Margin="10"
													Padding="10"
													Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}"
													BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
													BorderThickness="2"
													CornerRadius="5">
													<Border.Style>
														<Style TargetType="Border">
															<Style.Triggers>
																<DataTrigger Binding="{Binding AltPressed}" Value="True">
																	<Setter Property="BorderBrush" Value="White" />
																	<Setter Property="BorderThickness" Value="1" />
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<Image HorizontalAlignment="Center" VerticalAlignment="Center" Source="{DynamicResource PrivacyShield}" />
												</Border>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</Grid>
							</Border>
						</StackPanel>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:BrowserViewModel}">
						<StackPanel Margin="2">
							<StackPanel.Style>
								<Style TargetType="StackPanel">
									<Setter Property="Visibility" Value="Visible" />
									<Style.Triggers>
										<DataTrigger Binding="{Binding Model.Disabled}" Value="True">
											<Setter Property="UIElement.Visibility" Value="Collapsed" />
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</StackPanel.Style>
							<!--  Main browser row: a border wrapping the select area + optional expand + privacy  -->
							<Border
								MinHeight="72"
								Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}"
								BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
								BorderThickness="1"
								CornerRadius="5">
								<Grid MinHeight="72" VerticalAlignment="Stretch">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<!--  Select: the main clickable area (icon + name)  -->
									<Button
										Grid.Column="0"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"
										Command="{Binding Select}"
										CommandParameter="{Binding Path=DataContext.Url.TargetURL, RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Grid MinHeight="72" VerticalAlignment="Stretch" Background="Transparent" Cursor="Hand">
													<Grid.Style>
														<Style>
															<Style.Triggers>
																<Trigger Property="Grid.IsMouseOver" Value="True">
																	<Setter Property="Grid.Background" Value="#22ffffff" />
																</Trigger>
															</Style.Triggers>
														</Style>
													</Grid.Style>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition Width="*" MinWidth="310" />
													</Grid.ColumnDefinitions>
													<Image
														Width="40"
														Height="40"
														Margin="20,0,0,0"
														VerticalAlignment="Center"
														d:DataContext="{DynamicResource DefaultIcon}"
														DataContext="{Binding Model.IconPath, Converter={StaticResource IconConverter}}">
														<Image.Style>
															<Style TargetType="{x:Type Image}">
																<Setter Property="Source" Value="{Binding}" />
																<Style.Triggers>
																	<DataTrigger Binding="{Binding}" Value="{x:Null}">
																		<Setter Property="Source" Value="{DynamicResource DefaultIcon}" />
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Image.Style>
													</Image>
													<TextBlock
														Grid.Column="1"
														Margin="20"
														VerticalAlignment="Center"
														FontSize="18"
														Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
														LineHeight="22"
														Text="{Binding Model.Name}">
														<TextBlock.Style>
															<Style>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsRunning}" Value="True">
																		<Setter Property="TextBlock.FontWeight" Value="Bold" />
																	</DataTrigger>
																	<DataTrigger Binding="{Binding IsRunning}" Value="False">
																		<Setter Property="TextBlock.FontStyle" Value="Italic" />
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
												</Grid>
											</ControlTemplate>
										</Button.Template>
									</Button>
									<!--  Expand/collapse toggle for browsers with profiles  -->
									<Button Grid.Column="1" VerticalAlignment="Stretch" Command="{Binding ExpandToggle}" ToolTip="Show profiles">
										<Button.Style>
											<Style TargetType="Button">
												<Setter Property="Visibility" Value="Collapsed" />
												<Style.Triggers>
													<DataTrigger Binding="{Binding ShowNestedProfilesInPicker}" Value="True">
														<Setter Property="Visibility" Value="Visible" />
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<Button.Template>
											<ControlTemplate>
												<Border
													x:Name="ChevronBorder"
													Padding="10,0"
													VerticalAlignment="Stretch"
													Background="Transparent"
													Cursor="Hand">
													<Path
														x:Name="ChevronPath"
														HorizontalAlignment="Center"
														VerticalAlignment="Center"
														Data="M 0,0 L 4,3.5 L 0,7"
														Opacity="0.5"
														RenderTransformOrigin="0.5,0.5"
														Stroke="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
														StrokeEndLineCap="Round"
														StrokeLineJoin="Round"
														StrokeStartLineCap="Round"
														StrokeThickness="1.5">
														<Path.Style>
															<Style TargetType="Path">
																<Setter Property="RenderTransform">
																	<Setter.Value>
																		<RotateTransform Angle="0" />
																	</Setter.Value>
																</Setter>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsExpanded}" Value="True">
																		<Setter Property="RenderTransform">
																			<Setter.Value>
																				<RotateTransform Angle="90" />
																			</Setter.Value>
																		</Setter>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Path.Style>
													</Path>
												</Border>
												<ControlTemplate.Triggers>
													<Trigger SourceName="ChevronBorder" Property="IsMouseOver" Value="True">
														<Setter TargetName="ChevronBorder" Property="Background" Value="#22ffffff" />
														<Setter TargetName="ChevronPath" Property="Opacity" Value="1" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
									<!--  Privacy mode button  -->
									<Button Grid.Column="2" VerticalAlignment="Stretch" Command="{Binding SelectPrivacy}" ToolTip="{Binding PrivacyTooltip}">
										<Button.Style>
											<Style TargetType="Button">
												<Style.Triggers>
													<Trigger Property="IsEnabled" Value="False">
														<Setter Property="UIElement.Visibility" Value="Collapsed" />
													</Trigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<Button.Template>
											<ControlTemplate>
												<Border
													Width="40"
													Height="40"
													Margin="10"
													Padding="10"
													Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}"
													BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
													BorderThickness="2"
													CornerRadius="5">
													<Border.Style>
														<Style TargetType="Border">
															<Style.Triggers>
																<DataTrigger Binding="{Binding AltPressed}" Value="True">
																	<Setter Property="BorderBrush" Value="White" />
																	<Setter Property="BorderThickness" Value="1" />
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<Image HorizontalAlignment="Center" VerticalAlignment="Center" Source="{DynamicResource PrivacyShield}" />
												</Border>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</Grid>
							</Border>
							<!--  Profile sub-entries (visible when expanded in grouped mode only)  -->
							<DockPanel Margin="55,2,2,4">
								<DockPanel.Style>
									<Style TargetType="DockPanel">
										<Setter Property="Visibility" Value="Collapsed" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding ShowNestedProfileSubtree}" Value="True">
												<Setter Property="Visibility" Value="Visible" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</DockPanel.Style>
								<Border
									Width="2"
									Margin="0,2"
									Background="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
									CornerRadius="1"
									DockPanel.Dock="Left"
									Opacity="0.2" />
								<ItemsControl ItemsSource="{Binding ProfileViewModels}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Orientation="Vertical" />
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate DataType="viewModels:BrowserProfileViewModel">
											<Button Command="{Binding Select}">
												<Button.Template>
													<ControlTemplate TargetType="Button">
														<Border
															x:Name="ProfileBg"
															Padding="12,5"
															Background="Transparent"
															CornerRadius="0,3,3,0"
															Cursor="Hand">
															<StackPanel Orientation="Horizontal">
																<Path
																	Width="14"
																	Height="14"
																	Margin="0,0,8,0"
																	VerticalAlignment="Center"
																	Data="{Binding Model.ContainerIcon, Converter={StaticResource ContainerIconConverter}}"
																	Fill="{Binding Model.IconColor, Converter={StaticResource ContainerColorConverter}}"
																	Stretch="Uniform">
																	<Path.Style>
																		<Style TargetType="Path">
																			<Setter Property="Visibility" Value="Visible" />
																			<Style.Triggers>
																				<DataTrigger Binding="{Binding Model.ContainerIcon}" Value="{x:Null}">
																					<Setter Property="Visibility" Value="Collapsed" />
																				</DataTrigger>
																			</Style.Triggers>
																		</Style>
																	</Path.Style>
																</Path>
																<TextBlock VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Text="{Binding Model.Name}" />
															</StackPanel>
														</Border>
														<ControlTemplate.Triggers>
															<Trigger SourceName="ProfileBg" Property="IsMouseOver" Value="True">
																<Setter TargetName="ProfileBg" Property="Background" Value="#18ffffff" />
															</Trigger>
														</ControlTemplate.Triggers>
													</ControlTemplate>
												</Button.Template>
											</Button>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</DockPanel>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.Resources>
			</ItemsControl>
		</ScrollViewer>
		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
				<TextBlock VerticalAlignment="Center">
					<Hyperlink Command="{Binding Configure}" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}">
						<TextBlock Text="Configure browser list" />
					</Hyperlink>
				</TextBlock>
				<TextBlock VerticalAlignment="Center" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Opacity="0.6" Text="  ·  " />
				<TextBlock VerticalAlignment="Center">
					<Hyperlink Command="{Binding Feedback}" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}">
						<TextBlock Text="Feedback" />
					</Hyperlink>
				</TextBlock>
			</StackPanel>
			<CheckBox
				Grid.Row="0"
				Grid.Column="1"
				Margin="12,0,0,0"
				HorizontalAlignment="Right"
				VerticalAlignment="Center"
				Content="Always ask"
				Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
				IsChecked="{Binding Configuration.Settings.AlwaysPrompt, UpdateSourceTrigger=PropertyChanged}" />
			<StackPanel
				Grid.Row="1"
				Grid.Column="0"
				Grid.ColumnSpan="2"
				Width="350"
				Margin="0,4,0,0"
				HorizontalAlignment="Left">
				<StackPanel.Style>
					<Style TargetType="StackPanel">
						<Setter Property="Visibility" Value="Visible" />
						<Style.Triggers>
							<DataTrigger Binding="{Binding Url.CanRememberChoice}" Value="False">
								<Setter Property="Visibility" Value="Collapsed" />
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</StackPanel.Style>
				<CheckBox IsChecked="{Binding Configuration.AutoAddDefault}">
					<StackPanel Orientation="Horizontal">
						<TextBlock Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Text="Remember " />
						<TextBlock Style="{StaticResource RememberValueTextBlockStyle}" Text="{Binding Url.HostName}" ToolTip="{Binding Url.HostName}" />
					</StackPanel>
				</CheckBox>
				<StackPanel Margin="0,2,0,0">
					<StackPanel.Style>
						<Style TargetType="StackPanel">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Url.CanRememberRegistrableDomain}" Value="False">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</StackPanel.Style>
					<CheckBox IsChecked="{Binding Configuration.AutoAddRegistrableDefault}">
						<StackPanel Orientation="Horizontal">
							<TextBlock Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Text="Remember " />
							<TextBlock Style="{StaticResource RememberValueTextBlockStyle}" Text="{Binding Url.RegistrableDomain, Mode=OneWay}" ToolTip="{Binding Url.RegistrableDomain}" />
						</StackPanel>
					</CheckBox>
				</StackPanel>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
