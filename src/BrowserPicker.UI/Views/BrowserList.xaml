<UserControl
	x:Class="BrowserPicker.UI.Views.BrowserList"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:viewModels="clr-namespace:BrowserPicker.UI.ViewModels"
	xmlns:converters="clr-namespace:BrowserPicker.UI.Converters"
	xmlns:ui="clr-namespace:BrowserPicker.UI"
	mc:Ignorable="d"
	d:DataContext="{d:DesignInstance viewModels:ApplicationViewModel,d:IsDesignTimeCreatable=true}">
	<UserControl.Resources>
		<ResourceDictionary>
			<converters:IconFileToImageConverter x:Key="IconConverter" />
			<converters:ContainerColorConverter x:Key="ContainerColorConverter" />
			<converters:ContainerIconConverter x:Key="ContainerIconConverter" />
		</ResourceDictionary>
	</UserControl.Resources>
	<Grid MinWidth="350">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<StackPanel Orientation="Vertical" Margin="0,0,50,0">
			<StackPanel Orientation="Horizontal">
				<Image Source="{DynamicResource DefaultIcon}" Height="16" Margin="5" />
				<TextBlock Margin="0,5">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Configuration.AutoCloseOnFocusLost}" Value="False">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
					<Hyperlink TextDecorations="None" Command="{Binding PinWindow}" ToolTip="Toggle whether this picker window stays open when it loses focus">
						<Hyperlink.Style>
							<Style TargetType="{x:Type Hyperlink}">
								<Setter Property="Foreground" Value="Silver" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Pinned}" Value="True">
										<Setter Property="Foreground" Value="Orange" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Hyperlink.Style>
						📌
					</Hyperlink>
				</TextBlock>
				<TextBlock Margin="0,5">
					<Hyperlink TextDecorations="None" Command="{Binding CopyUrl}" ToolTip="Copy the URL to the clipboard">
						<Hyperlink.Style>
							<Style TargetType="{x:Type Hyperlink}">
								<Setter Property="Foreground" Value="Silver" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Copied}" Value="True">
										<Setter Property="Foreground" Value="White" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Hyperlink.Style>
						📋
					</Hyperlink>
					<Hyperlink TextDecorations="None" Command="{Binding Edit}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" ToolTip="Edit the URL before opening it">
						✏
					</Hyperlink>
				</TextBlock>
				<TextBlock Text="Redirected URL" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="5,5,0,0">
					<TextBlock.Style>
						<Style>
							<Style.Triggers>
								<DataTrigger Binding="{Binding Url.IsShortenedURL}" Value="False">
									<Setter Property="UIElement.Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>
			</StackPanel>
			<Border Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}" CornerRadius="5" Padding="2" Margin="2">
				<TextBlock Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxWidth="380" MaxHeight="100">
					<Image Source="{Binding Url.FavIcon}" Height="16" Width="16" Margin="0,-3" />
					<Run Text="{Binding Url.DisplayURL, Mode=OneWay}" />
				</TextBlock>
			</Border>
		</StackPanel>
		<ScrollViewer x:Name="BrowserListScroll" Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" SizeChanged="BrowserListScroll_SizeChanged">
			<ItemsControl ItemsSource="{Binding PickerChoices}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Vertical" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.Resources>
					<DataTemplate DataType="{x:Type viewModels:BrowserProfileViewModel}">
						<StackPanel Margin="2">
							<!-- Same column layout and min height as browser rows (chevron + privacy columns reserved) for visual alignment -->
							<Border MinHeight="72" CornerRadius="5" Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}" BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" BorderThickness="1">
								<Grid MinHeight="72" VerticalAlignment="Stretch">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<Button Grid.Column="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Command="{Binding Select}" CommandParameter="{Binding Path=DataContext.Url.TargetURL,RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Grid MinHeight="72" Cursor="Hand" Background="Transparent" VerticalAlignment="Stretch">
													<Grid.Style>
														<Style>
															<Style.Triggers>
																<Trigger Property="Grid.IsMouseOver" Value="True">
																	<Setter Property="Grid.Background" Value="#22ffffff" />
																</Trigger>
															</Style.Triggers>
														</Style>
													</Grid.Style>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto" />
														<ColumnDefinition Width="*" />
													</Grid.ColumnDefinitions>
													<Image Margin="20,0,0,0" Width="40" Height="40" VerticalAlignment="Center" DataContext="{Binding IconPath, Converter={StaticResource IconConverter}}" d:DataContext="{DynamicResource DefaultIcon}">
														<Image.Style>
															<Style TargetType="{x:Type Image}">
																<Setter Property="Source" Value="{Binding}" />
																<Style.Triggers>
																	<DataTrigger Binding="{Binding}" Value="{x:Null}">
																		<Setter Property="Source" Value="{DynamicResource DefaultIcon}" />
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Image.Style>
													</Image>
													<StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,20,0" VerticalAlignment="Center">
														<Path
															Data="{Binding Model.ContainerIcon, Converter={StaticResource ContainerIconConverter}}"
															Fill="{Binding Model.IconColor, Converter={StaticResource ContainerColorConverter}}"
															Stretch="Uniform" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center">
															<Path.Style>
																<Style TargetType="Path">
																	<Setter Property="Visibility" Value="Visible" />
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding Model.ContainerIcon}" Value="{x:Null}">
																			<Setter Property="Visibility" Value="Collapsed" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</Path.Style>
														</Path>
														<TextBlock Text="{Binding FlatDisplayName}" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" FontSize="18" LineHeight="22" VerticalAlignment="Center">
															<TextBlock.Style>
																<Style>
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding IsRunning}" Value="True">
																			<Setter Property="TextBlock.FontWeight" Value="Bold" />
																		</DataTrigger>
																		<DataTrigger Binding="{Binding IsRunning}" Value="False">
																			<Setter Property="TextBlock.FontStyle" Value="Italic" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</TextBlock.Style>
														</TextBlock>
													</StackPanel>
												</Grid>
											</ControlTemplate>
										</Button.Template>
									</Button>
									<Border Grid.Column="1" Width="34" Background="Transparent" IsHitTestVisible="False" />
									<Button
										Grid.Column="2"
										VerticalAlignment="Stretch"
										Command="{Binding SelectPrivacy}"
										ToolTip="{Binding PrivacyTooltip}"
										IsEnabled="{Binding HasPrivacyMode}">
										<Button.Style>
											<Style TargetType="Button">
												<Style.Triggers>
													<Trigger Property="IsEnabled" Value="False">
														<Setter Property="UIElement.Visibility" Value="Collapsed" />
													</Trigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
										<Button.Template>
											<ControlTemplate>
												<Border Margin="10" Padding="10" Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}" Width="40" Height="40" CornerRadius="5" BorderThickness="2" BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}">
													<Border.Style>
														<Style TargetType="Border">
															<Style.Triggers>
																<DataTrigger Binding="{Binding AltPressed}" Value="True">
																	<Setter Property="BorderBrush" Value="White" />
																	<Setter Property="BorderThickness" Value="1" />
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</Border.Style>
													<Image Source="{DynamicResource PrivacyShield}" HorizontalAlignment="Center" VerticalAlignment="Center" />
												</Border>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</Grid>
							</Border>
						</StackPanel>
					</DataTemplate>
					<DataTemplate DataType="{x:Type viewModels:BrowserViewModel}">
				<StackPanel Margin="2">
					<StackPanel.Style>
						<Style TargetType="StackPanel">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding Model.Disabled}" Value="True">
									<Setter Property="UIElement.Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</StackPanel.Style>
					<!-- Main browser row: a border wrapping the select area + optional expand + privacy -->
					<Border MinHeight="72" CornerRadius="5" Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}" BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" BorderThickness="1">
						<Grid MinHeight="72" VerticalAlignment="Stretch">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<!-- Select: the main clickable area (icon + name) -->
							<Button Grid.Column="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Command="{Binding Select}" CommandParameter="{Binding Path=DataContext.Url.TargetURL,RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}">
								<Button.Template>
									<ControlTemplate TargetType="Button">
										<Grid MinHeight="72" Cursor="Hand" Background="Transparent" VerticalAlignment="Stretch">
											<Grid.Style>
												<Style>
													<Style.Triggers>
														<Trigger Property="Grid.IsMouseOver" Value="True">
															<Setter Property="Grid.Background" Value="#22ffffff" />
														</Trigger>
													</Style.Triggers>
												</Style>
											</Grid.Style>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="Auto" />
												<ColumnDefinition Width="*" />
											</Grid.ColumnDefinitions>
											<Image Margin="20,0,0,0" Width="40" Height="40" VerticalAlignment="Center" DataContext="{Binding Model.IconPath, Converter={StaticResource IconConverter}}" d:DataContext="{DynamicResource DefaultIcon}">
												<Image.Style>
													<Style TargetType="{x:Type Image}">
														<Setter Property="Source" Value="{Binding}" />
														<Style.Triggers>
															<DataTrigger Binding="{Binding}" Value="{x:Null}">
																<Setter Property="Source" Value="{DynamicResource DefaultIcon}" />
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Image.Style>
											</Image>
											<TextBlock Text="{Binding Model.Name}" Grid.Column="1" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Margin="20" FontSize="18" LineHeight="22" VerticalAlignment="Center">
												<TextBlock.Style>
													<Style>
														<Style.Triggers>
															<DataTrigger Binding="{Binding IsRunning}" Value="True">
																<Setter Property="TextBlock.FontWeight" Value="Bold" />
															</DataTrigger>
															<DataTrigger Binding="{Binding IsRunning}" Value="False">
																<Setter Property="TextBlock.FontStyle" Value="Italic" />
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</TextBlock.Style>
											</TextBlock>
										</Grid>
									</ControlTemplate>
								</Button.Template>
							</Button>
							<!-- Expand/collapse toggle for browsers with profiles -->
							<Button Grid.Column="1" VerticalAlignment="Stretch" Command="{Binding ExpandToggle}" ToolTip="Show profiles">
								<Button.Style>
									<Style TargetType="Button">
										<Setter Property="Visibility" Value="Collapsed" />
										<Style.Triggers>
											<DataTrigger Binding="{Binding ShowNestedProfilesInPicker}" Value="True">
												<Setter Property="Visibility" Value="Visible" />
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Button.Style>
							<Button.Template>
								<ControlTemplate>
									<Border x:Name="ChevronBorder" Padding="10,0" Cursor="Hand" Background="Transparent" VerticalAlignment="Stretch">
										<Path x:Name="ChevronPath" Data="M 0,0 L 4,3.5 L 0,7" Stroke="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5" RenderTransformOrigin="0.5,0.5">
											<Path.Style>
												<Style TargetType="Path">
													<Setter Property="RenderTransform">
														<Setter.Value>
															<RotateTransform Angle="0" />
														</Setter.Value>
													</Setter>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsExpanded}" Value="True">
															<Setter Property="RenderTransform">
																<Setter.Value>
																	<RotateTransform Angle="90" />
																</Setter.Value>
															</Setter>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Path.Style>
										</Path>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger SourceName="ChevronBorder" Property="IsMouseOver" Value="True">
											<Setter TargetName="ChevronBorder" Property="Background" Value="#22ffffff" />
											<Setter TargetName="ChevronPath" Property="Opacity" Value="1" />
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Button.Template>
							</Button>
							<!-- Privacy mode button -->
							<Button Grid.Column="2" VerticalAlignment="Stretch" Command="{Binding SelectPrivacy}" ToolTip="{Binding PrivacyTooltip}">
								<Button.Style>
									<Style TargetType="Button">
										<Style.Triggers>
											<Trigger Property="IsEnabled" Value="False">
												<Setter Property="UIElement.Visibility" Value="Collapsed" />
											</Trigger>
										</Style.Triggers>
									</Style>
								</Button.Style>
								<Button.Template>
									<ControlTemplate>
										<Border Margin="10" Padding="10" Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}" Width="40" Height="40" CornerRadius="5" BorderThickness="2" BorderBrush="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}">
											<Border.Style>
												<Style TargetType="Border">
													<Style.Triggers>
														<DataTrigger Binding="{Binding AltPressed}" Value="True">
															<Setter Property="BorderBrush" Value="White" />
															<Setter Property="BorderThickness" Value="1" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Border.Style>
											<Image Source="{DynamicResource PrivacyShield}" HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>
									</ControlTemplate>
								</Button.Template>
							</Button>
						</Grid>
					</Border>
					<!-- Profile sub-entries (visible when expanded in grouped mode only) -->
					<DockPanel Margin="55,2,2,4">
						<DockPanel.Style>
							<Style TargetType="DockPanel">
								<Setter Property="Visibility" Value="Collapsed" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding ShowNestedProfileSubtree}" Value="True">
										<Setter Property="Visibility" Value="Visible" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</DockPanel.Style>
						<Border DockPanel.Dock="Left" Width="2" Background="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Opacity="0.2" CornerRadius="1" Margin="0,2" />
						<ItemsControl ItemsSource="{Binding ProfileViewModels}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<StackPanel Orientation="Vertical" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate DataType="viewModels:BrowserProfileViewModel">
									<Button Command="{Binding Select}">
										<Button.Template>
											<ControlTemplate TargetType="Button">
												<Border x:Name="ProfileBg" Cursor="Hand" Background="Transparent" Padding="12,5" CornerRadius="0,3,3,0">
													<StackPanel Orientation="Horizontal">
														<Path
															Data="{Binding Model.ContainerIcon, Converter={StaticResource ContainerIconConverter}}"
															Fill="{Binding Model.IconColor, Converter={StaticResource ContainerColorConverter}}"
															Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
															<Path.Style>
																<Style TargetType="Path">
																	<Setter Property="Visibility" Value="Visible" />
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding Model.ContainerIcon}" Value="{x:Null}">
																			<Setter Property="Visibility" Value="Collapsed" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</Path.Style>
														</Path>
														<TextBlock Text="{Binding Model.Name}" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" FontSize="13" VerticalAlignment="Center" />
													</StackPanel>
												</Border>
												<ControlTemplate.Triggers>
													<Trigger SourceName="ProfileBg" Property="IsMouseOver" Value="True">
														<Setter TargetName="ProfileBg" Property="Background" Value="#18ffffff" />
													</Trigger>
												</ControlTemplate.Triggers>
											</ControlTemplate>
										</Button.Template>
									</Button>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</DockPanel>
				</StackPanel>
					</DataTemplate>
				</ItemsControl.Resources>
			</ItemsControl>
		</ScrollViewer>
		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
				<TextBlock VerticalAlignment="Center">
					<Hyperlink Command="{Binding Configure}" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}">
						<TextBlock Text="Configure browser list" />
					</Hyperlink>
				</TextBlock>
				<TextBlock Text="  ·  " Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Opacity="0.6" VerticalAlignment="Center" />
				<TextBlock VerticalAlignment="Center">
					<Hyperlink Command="{Binding Feedback}" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}">
						<TextBlock Text="Feedback" />
					</Hyperlink>
				</TextBlock>
			</StackPanel>
			<CheckBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding Configuration.Settings.AlwaysPrompt, UpdateSourceTrigger=PropertyChanged}" Content="Always ask" Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" Margin="12,0,0,0" />
			<CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" IsChecked="{Binding Configuration.AutoAddDefault}" Width="350" Margin="0,4,0,0">
				<TextBlock Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}" TextWrapping="Wrap" MaxHeight="50">
					<Run Text="Remember my choice for" />
					<Run Text="{Binding Url.HostName}" />
				</TextBlock>
			</CheckBox>
		</Grid>
	</Grid>
</UserControl>
