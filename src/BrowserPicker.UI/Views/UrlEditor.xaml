<Window
	x:Class="BrowserPicker.UI.Views.UrlEditor"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:ui="clr-namespace:BrowserPicker.UI"
	x:Name="Self"
	Title="Edit URL"
	Width="720"
	Height="240"
	MinWidth="520"
	MinHeight="220"
	Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}"
	Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}"
	Loaded="Window_OnLoaded"
	PreviewKeyUp="Window_OnPreviewKeyUp"
	ShowInTaskbar="False"
	WindowStartupLocation="CenterOwner"
	mc:Ignorable="d">
	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<TextBlock Margin="0,0,0,8" FontSize="16" Text="Edit target URL" />
		<TextBox
			x:Name="EditorTextBox"
			Grid.Row="1"
			Padding="8,6"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			VerticalContentAlignment="Top"
			AcceptsReturn="True"
			HorizontalScrollBarVisibility="Disabled"
			MaxLines="8"
			MinLines="5"
			Text="{Binding EditedUrl, ElementName=Self, UpdateSourceTrigger=PropertyChanged}"
			TextWrapping="Wrap"
			VerticalScrollBarVisibility="Auto" />
		<StackPanel Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
			<Button Padding="12,4" Click="Cancel_OnClick" Content="Cancel" />
			<Button
				Margin="8,0,0,0"
				Padding="12,4"
				Click="Save_OnClick"
				Content="OK"
				ToolTip="Save changes (Ctrl+Enter)" />
		</StackPanel>
	</Grid>
</Window>
