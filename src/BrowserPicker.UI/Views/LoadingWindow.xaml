<Window
	x:Class="BrowserPicker.UI.Views.LoadingWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewModels="clr-namespace:BrowserPicker.UI.ViewModels"
	xmlns:ui="clr-namespace:BrowserPicker.UI"
	Background="Transparent"
	mc:Ignorable="d"
	d:DataContext="{d:DesignInstance viewModels:ApplicationViewModel,d:IsDesignTimeCreatable=true}"
	Title="Browser Picker" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
	AllowsTransparency="True" WindowStyle="None"
	ShowInTaskbar="False" SizeChanged="Window_SizeChanged">
	<Border CornerRadius="5" BorderBrush="#22FFFFFF" BorderThickness="2"
		Background="{DynamicResource {x:Static ui:App.ContentBackgroundBrushKey}}">
		<Border.Style>
			<Style TargetType="{x:Type Border}">
				<Setter Property="Opacity" Value="1" />
				<Style.Triggers>
					<DataTrigger Binding="{Binding DisableTransparency, Source={x:Static ui:App.Settings}}" Value="False">
						<Setter Property="Opacity" Value="{Binding WindowOpacity, Source={x:Static ui:App.Settings}}" />
					</DataTrigger>
				</Style.Triggers>
			</Style>
		</Border.Style>
		<Grid Margin="10" TextElement.Foreground="{DynamicResource {x:Static ui:App.ContentForegroundBrushKey}}">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<TextBlock Margin="20" FontSize="18">Scanning URL...</TextBlock>
			<TextBlock Grid.Row="1" Text="{Binding Url.UnderlyingTargetURL}" Margin="5" TextWrapping="WrapWithOverflow" TextTrimming="CharacterEllipsis" MaxWidth="380" />
		</Grid>
	</Border>
</Window>
